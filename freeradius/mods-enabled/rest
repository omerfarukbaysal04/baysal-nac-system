rest {
    connect_uri = "http://api:8000"

    connect_timeout = 3.0
    timeout         = 5.0

    authorize {
        uri    = "${..connect_uri}/authorize"
        method = "post"
        body   = "json"
    }

    authenticate {
        uri    = "${..connect_uri}/auth"
        method = "post"
        body   = "json"
    }

    accounting {
        uri    = "${..connect_uri}/accounting"
        method = "post"
        body   = "json"
    }
}