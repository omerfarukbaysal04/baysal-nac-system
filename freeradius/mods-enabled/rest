rest {
    # FastAPI container'inin adresi.
    # Docker network icerisinde container adi ile erisiyoruz.
    connect_uri = "http://api:8000"

    connect_timeout = 3.0
    timeout         = 5.0

    # /authorize: Kimlik dogrulama sonrasi VLAN attribute'lerini almak icin
    authorize {
        uri    = "${..connect_uri}/authorize"
        method = "post"
        body   = "json"
        tls    = ${..tls}
    }

    # /auth: Kullanici adi ve sifre dogrulama icin
    authenticate {
        uri    = "${..connect_uri}/auth"
        method = "post"
        body   = "json"
        tls    = ${..tls}
    }

    # /accounting: Oturum verisi kaydetmek icin
    accounting {
        uri    = "${..connect_uri}/accounting"
        method = "post"
        body   = "json"
        tls    = ${..tls}
    }
}
