server default {

    listen {
        type        = auth
        ipaddr      = *
        port        = 1812
    }

    listen {
        type        = acct
        ipaddr      = *
        port        = 1813
    }

    authorize {
        filter_username
        rest
        pap
    }

   authenticate {
        Auth-Type Rest {
            rest
            if (updated) {
                ok
            }
            else {
                reject
            }
        }
    }
    accounting {
        rest
    }

    post-auth {
        rest

        Post-Auth-Type REJECT {
            attr_filter.access_reject
        }
    }
}